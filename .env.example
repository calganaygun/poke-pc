POKE_API_KEY=
POKE_API=https://poke.com/api/v1
POKE_TUNNEL_NAME=poke-pc
MCP_HOST=0.0.0.0
MCP_PORT=3000
MCP_PUBLIC_URL=http://127.0.0.1:3000/mcp
POKE_PC_STATE_DIR=/root/poke-pc
POKE_PC_BOOTSTRAP_FILE=./config/bootstrap-example.yaml
POKE_PC_BOOTSTRAP_CONFIG=/runtime/bootstrap.yaml
POKE_PC_BOOTSTRAP_COMMANDS=
POKE_PC_BOOTSTRAP_STRICT=false
POKE_PC_RESTORE_SESSIONS=true
POKE_PC_AUTOREGISTER_WEBHOOK=false
POKE_PC_WEBHOOK_CONDITION=When terminal commands are long-running or complete
POKE_PC_WEBHOOK_ACTION=Notify me with command progress heartbeat and completion details
POKE_PC_LONG_RUNNING_THRESHOLD_MS=60000
POKE_PC_HEARTBEAT_INTERVAL_MS=30000
POKE_PC_MONITOR_INTERVAL_MS=5000
POKE_PC_TUNNEL_SYNC_INTERVAL_MS=300000
LOG_LEVEL=info
