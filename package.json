{
  "name": "poke-pc",
  "version": "0.1.2",
  "description": "Dockerized Poke PC MCP worker with tmux terminal control, Poke tunnel, and adaptive webhook notifications.",
  "main": "dist/index.js",
  "bin": "./scripts/quickstart.mjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "quickstart": "node scripts/quickstart.mjs",
    "sync:version": "node scripts/sync-version-from-tag.mjs"
  },
  "keywords": [
    "poke",
    "mcp",
    "tmux",
    "docker",
    "agent"
  ],
  "author": "calganaygun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/calganaygun/poke-pc.git"
  },
  "bugs": {
    "url": "https://github.com/calganaygun/poke-pc/issues"
  },
  "homepage": "https://github.com/calganaygun/poke-pc#readme",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "poke": "^0.4.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
